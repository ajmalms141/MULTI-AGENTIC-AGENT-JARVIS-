# =============================================================
#  JARVIS — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit the .env file. Only commit this .env.example
# =============================================================

# ---------------------------
# LLM — Google Gemini 1.5 Flash
# Get it free at: https://aistudio.google.com/app/apikey
# ---------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------
# Images — Unsplash (for slide images)
# Get it free at: https://unsplash.com/developers
# ---------------------------
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ---------------------------
# Email — Gmail SMTP (App Password, easiest setup)
# Steps: Google Account → Security → 2-Step Verification → App Passwords
# ---------------------------
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ---------------------------
# Service Ports (change only if there's a conflict)
# ---------------------------
ORCHESTRATOR_PORT=8000
PRESENTATION_PORT=8001
PRICE_COMPARE_PORT=8002
EMAIL_SERVICE_PORT=8003
FRONTEND_PORT=3000
N8N_PORT=5678

# ---------------------------
# Redis (leave as-is for Docker)
# ---------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------
# SQLite Audit Log Path
# ---------------------------
SQLITE_DB_PATH=/data/audit.db
